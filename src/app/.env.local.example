# ============================================================
# TransPro CI — Frontend (Next.js)
# Copier en .env.local à la racine de apps/frontend
# ============================================================

# URL de l'API NestJS
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# URL Socket.io (même host que l'API, sans /api/v1)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Cartes — laisser vide pour Leaflet/OpenStreetMap (gratuit)
# NEXT_PUBLIC_MAP_PROVIDER=mapbox
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiLi4uIiwiYSI6Ii4uLiJ9.xxxxx

# QZ Tray — impression thermique (serveur Next.js uniquement)
# QZ_PRIVATE_KEY_PATH=/absolute/path/to/qz/private.pem
# QZ_PRIVATE_KEY=                    # alternative : contenu de la clé
